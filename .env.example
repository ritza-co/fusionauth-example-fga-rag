# NextAuth
AUTH_SECRET=super-secret-at-least-32-chars!!
AUTH_FUSIONAUTH_CLIENT_ID=e9fdb985-9173-4e01-9d73-ac2d60d1dc8e
AUTH_FUSIONAUTH_CLIENT_SECRET=super-secret-client-secret
AUTH_FUSIONAUTH_TENANT_ID=
AUTH_FUSIONAUTH_ISSUER=http://localhost:9011

# AI Provider — set to "openai" or "anthropic" (default: openai)
AI_PROVIDER=openai

# OpenAI (chat + embeddings) - https://platform.openai.com
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Anthropic (chat) - https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Voyage AI (embeddings for Anthropic provider) - https://voyageai.com
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-lite

# Permify
PERMIFY_BASE_URL=http://localhost:3476/v1
PERMIFY_TENANT_ID=t1
PERMIFY_PRESHARED_KEY=

# FusionAuth API key (set by kickstart — used to resolve user names on the org page)
FUSIONAUTH_API_KEY=bf69486b-4733-4470-a592-f1bc7a64f314

# Document persistence (optional, enables durable RAG docs)
# Example local value: postgres://postgres:postgres@localhost:5433/fusionauth
DOCUMENTS_DATABASE_URL=

# FusionAuth Docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_USERNAME=fusionauth
# Leave empty — FusionAuth creates this user automatically in development mode
DATABASE_PASSWORD=
FUSIONAUTH_APP_MEMORY=512M
FUSIONAUTH_APP_RUNTIME_MODE=development
