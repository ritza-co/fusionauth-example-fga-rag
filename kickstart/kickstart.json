{
    "variables": {
      "apiKey": "33052c8a-c283-4e96-9d2a-eb1215c69f8f-not-for-prod",
      "asymmetricKeyId": "#{UUID()}",
      "applicationId": "e9fdb985-9173-4e01-9d73-ac2d60d1dc8e",
      "clientSecret": "super-secret-secret-that-should-be-regenerated-for-production",
      "defaultTenantId": "d7d09513-a3f5-401c-9685-34ab6c552453",
      "adminEmail": "admin@example.com",
      "adminPassword": "password",
      "adminUserId": "00000000-0000-0000-0000-000000000001",
      "janeEmail": "jane@example.com",
      "janePassword": "password",
      "janeUserId": "00000000-0000-0000-0000-000000000002",
      "johnEmail": "john@example.com",
      "johnPassword": "password",
      "johnUserId": "00000000-0000-0000-0000-000000000003",
      "strangerEmail": "stranger@example.com",
      "strangerPassword": "password",
      "strangerUserId": "00000000-0000-0000-0000-000000000004"
    },
    "apiKeys": [
      {
        "key": "#{apiKey}",
        "description": "Unrestricted API key"
      }
    ],
    "requests": [
      {
        "method": "PATCH",
        "url": "/api/tenant/#{defaultTenantId}",
        "body": {
          "tenant": {
            "issuer": "http://localhost:9011"
          }
        }
      },
      {
        "method": "POST",
        "url": "/api/key/generate/#{asymmetricKeyId}",
        "tenantId": "#{defaultTenantId}",
        "body": {
          "key": {
            "algorithm": "RS256",
            "name": "For example app",
            "length": 2048
          }
        }
      },
      {
        "method": "POST",
        "url": "/api/application/#{applicationId}",
        "tenantId": "#{defaultTenantId}",
        "body": {
          "application": {
            "name": "Example App",
            "oauthConfiguration": {
              "authorizedRedirectURLs": [
                "http://localhost:3000/api/auth/callback/fusionauth"
              ],
              "logoutURL": "http://localhost:3000",
              "clientSecret": "#{clientSecret}",
              "enabledGrants": [
                "authorization_code",
                "refresh_token"
              ],
              "generateRefreshTokens": true,
              "requireRegistration": true
            },
            "jwtConfiguration": {
              "enabled": true,
              "accessTokenKeyId": "#{asymmetricKeyId}",
              "idTokenKeyId": "#{asymmetricKeyId}"
            },
            "registrationConfiguration": {
              "enabled": true,
              "type": "basic"
            },
            "roles": [
              {
                "name": "admin",
                "isDefault": false,
                "isSuperRole": true
              }
            ]
          }
        }
      },
      {
        "method": "POST",
        "url": "/api/user/registration/#{adminUserId}",
        "body": {
          "registration": {
            "applicationId": "#{applicationId}",
            "roles": [
              "admin"
            ]
          },
          "roles": [
            "admin"
          ],
          "skipRegistrationVerification": true,
          "user": {
            "birthDate": "1981-06-04",
            "email": "#{adminEmail}",
            "firstName": "Admin",
            "lastName": "User",
            "password": "#{adminPassword}"
          }
        }
      },
      {
        "method": "POST",
        "url": "/api/user/registration/#{janeUserId}",
        "body": {
          "user": {
            "birthDate": "1990-03-15",
            "email": "#{janeEmail}",
            "firstName": "Jane",
            "lastName": "Doe",
            "password": "#{janePassword}"
          },
          "registration": {
            "applicationId": "#{applicationId}"
          }
        }
      },
      {
        "method": "POST",
        "url": "/api/user/registration/#{johnUserId}",
        "body": {
          "user": {
            "birthDate": "1992-07-22",
            "email": "#{johnEmail}",
            "firstName": "John",
            "lastName": "Smith",
            "password": "#{johnPassword}"
          },
          "registration": {
            "applicationId": "#{applicationId}"
          }
        }
      },
      {
        "method": "POST",
        "url": "/api/user/registration/#{strangerUserId}",
        "body": {
          "user": {
            "birthDate": "1988-11-10",
            "email": "#{strangerEmail}",
            "firstName": "Stranger",
            "lastName": "Noaccess",
            "password": "#{strangerPassword}"
          },
          "registration": {
            "applicationId": "#{applicationId}"
          }
        }
      }
    ]
  }
